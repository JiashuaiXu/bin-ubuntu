#!/bin/bash
# 临时使用代理执行命令（不会影响当前 shell 的环境变量）

# 检查是否传入了命令
if [[ $# -eq 0 ]]; then
  echo "用法: with-proxy <command> [args...]" >&2
  echo "注意: 该工具仅对支持代理的程序有效（如 curl, wget, git, npm 等）" >&2
  echo "      ping / traceroute 等网络诊断工具不走代理！" >&2
  exit 1
fi

# 获取第一个命令名（去除路径）
cmd=$(basename "$1")

# 检测是否为不支持代理的命令
case "$cmd" in
  ping|ping6|traceroute|traceroute6|mtr|ip|ifconfig|netstat|ss)
    echo "⚠️  警告: '$cmd' 使用 ICMP 或直接网络访问，不支持 HTTP/SOCKS 代理！" >&2
    echo "   代理设置将被忽略，命令将直接使用本机网络。" >&2
    echo "" >&2
    ;;
esac

# 你的代理地址
HTTP_PROXY="http://192.168.10.254:20171"
HTTPS_PROXY="http://192.168.10.254:20171"
ALL_PROXY="socks5://192.168.10.254:20170"

# 执行命令
env \
  http_proxy="$HTTP_PROXY" \
  https_proxy="$HTTPS_PROXY" \
  HTTP_PROXY="$HTTP_PROXY" \
  HTTPS_PROXY="$HTTPS_PROXY" \
  all_proxy="$ALL_PROXY" \
  ALL_PROXY="$ALL_PROXY" \
  "$@"
